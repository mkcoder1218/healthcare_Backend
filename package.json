{
  "name": "backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "seed": "ts-node src/scripts/seed-db.ts",
    "init-db": "ts-node src/scripts/init-db.ts",
    "reset-db": "ts-node src/scripts/reset-db.ts",
    "verify-db": "ts-node src/scripts/verify-db.ts",
    "setup-db": "npm run init-db && npm run seed",
    "rebuild-db": "npm run reset-db && npm run setup-db",
    "create-admin": "ts-node src/scripts/create-admin.ts",
    "update-admin-password": "ts-node src/scripts/update-admin-password.ts",
    "init-activity-logs": "ts-node src/scripts/init-activity-logs.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Mental Healthcare Consultancy Backend API",
  "dependencies": {
    "@types/multer": "^2.0.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.1",
    "node-fetch": "^3.3.2",
    "pg": "^8.11.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.6.0",
    "@types/pg": "^8.10.2",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
